# petcare/.env

# Configurações do banco de dados PostgreSQL
DB_HOST=db
POSTGRES_DB=petcare_db
POSTGRES_USER=petcare_user
POSTGRES_PASSWORD=securepassword

# Configurações do pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@petcare.com
PGADMIN_DEFAULT_PASSWORD=admin

#Configurações para envio de e-mail
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=petcare@gmail.com
MAIL_PASSWORD=petcarepassword
MAIL_DEFAULT_SENDER=petcare@gmail.com